FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY package.json ./
RUN npm install --legacy-peer-deps

# Copy application code
COPY . .

# Set production environment
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Build Next.js
RUN npm run build

# Expose port
EXPOSE 3000

# Start Next.js
CMD ["npm", "start"]
