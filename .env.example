# Скопируйте в .env на сервере (рядом с docker-compose.prod.yml) и подставьте секреты.

# База
POSTGRES_USER=qlin
POSTGRES_PASSWORD=СЛОЖНЫЙ_ПАРОЛЬ
POSTGRES_DB=qlin

# Бэкенд
SECRET_KEY=длинная-случайная-строка
# Добавьте origin CRM: поддомен, локальный порт и при входе по IP — http://ВАШ_IP:3002
CORS_ORIGINS=https://qlin.pro,https://www.qlin.pro,https://crm.qlin.pro,http://localhost:3001,http://89.23.97.28:3002

# Публичный URL сайта (ссылка в письме сброса пароля)
PUBLIC_SITE_URL=https://qlin.pro

# SMTP — восстановление пароля по email (Яндекс: smtp.yandex.ru, порт 465 SSL или 587 STARTTLS)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Telegram (если используете)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Фронт (вшиваются при docker build frontend — после смены пересоберите образ)
NEXT_PUBLIC_API_URL=https://qlin.pro
NEXT_PUBLIC_SITE_URL=https://qlin.pro
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
